# .env.example — Template for local Docker Deployment
# Copy this file to .env and fill in your own values
# The .env file is ignored by Git (.gitignore)

# =====================
# Database Settings
# =====================
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=blogs
DB_PORT=5432

# =====================
# Redis Settings
# =====================
REDIS_PORT=6379

# =====================
# API Settings
# =====================
ASPNETCORE_ENVIRONMENT=Development
# IMPORTANT: Change this to a strong random secret (min 32 chars) in production!
JWT_SECRET=change-this-to-a-secure-random-secret-at-least-32-chars
SEED_DATA=true
API_PORT=8080

# =====================
# Cloudinary Settings (get from cloudinary.com/console)
# =====================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
