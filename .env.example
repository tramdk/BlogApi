# .env file template for Docker Deployment
# Update these values for your environment

# Database Settings
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=blogs
DB_PORT=5432

# Redis Settings
REDIS_PORT=6379

# API Settings
ASPNETCORE_ENVIRONMENT=Development
JWT_SECRET=YourSuperSecretKeyWithAtLeast32Characters! # IMPORTANT: Change this in production
SEED_DATA=true
API_PORT=8080
