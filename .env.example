# .env.example — Template for local Docker Deployment
# Copy this file to .env and fill in your own values
# The .env file is ignored by Git (.gitignore)

# =====================
# Database Settings
# =====================
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=blogs
DB_PORT=5432

# =====================
# Redis Settings
# =====================
REDIS_PORT=6379

# =====================
# API Settings
# =====================
ASPNETCORE_ENVIRONMENT=Development
# IMPORTANT: Change this to a strong random secret (min 32 chars) in production!
JWT_SECRET=change-this-to-a-secure-random-secret-at-least-32-chars
SEED_DATA=true
API_PORT=8080

# =====================
# Cloudinary Settings (get from cloudinary.com/console)
# =====================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =====================
# AI Developer Harness Settings
# =====================
# Chỉ cần điền 1 trong các khóa dưới đây để kích hoạt AI Agent lập trình thực tế cục bộ.
# Nếu để trống tất cả, hệ thống sẽ tự động chạy ở chế độ giả lập (Mock Mode).
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Tùy chọn cấu hình Model (Mặc định sẽ tự động chọn nếu không khai báo)
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o
CLAUDE_MODEL=claude-3-5-sonnet-latest
DEEPSEEK_MODEL=deepseek-chat

# Telegram Bot Settings (cho telegram_bot/bot.py)
# Tạo bot qua @BotFather, dùng lệnh /newbot rồi copy token dán vào đây
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Zalo Bot Settings (cho zalo_bot/bot.py)
# Lấy các thông tin cấu hình từ Zalo Developer Portal (https://developers.zalo.me)
ZALO_OA_ACCESS_TOKEN=your_zalo_oa_access_token_here
ZALO_PORT=8000
# Tùy chọn: Zalo User ID của Admin để chỉ cho phép Admin điều khiển bot
ZALO_ADMIN_USER_ID=your_zalo_admin_user_id_here

# Harness Configuration
# GAN max loop phase
GAN_MAX_ITERATIONS=10
# GAN pass score
GAN_PASS_THRESHOLD=7.5